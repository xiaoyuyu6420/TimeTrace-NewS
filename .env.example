# ─── TimeTrace 配置 ───
# 复制此文件为 .env 并填入实际值

# 管理员账号（首次启动时自动创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# JWT 配置
JWT_EXPIRE_HOURS=24

# 数据库
DATABASE_URL=sqlite:///./timetrace.db

# LLM 配置（支持 OpenAI 兼容 API）
LLM_API_KEY=
LLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL=

# 调试模式（生产环境请设为 false）
DEBUG=false
